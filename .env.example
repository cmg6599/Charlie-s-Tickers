# Copy to `.env` in the same folder as `server.js`:
#   cp .env.example .env
# Put your Finnhub token on ONE line after `=`. Restart `node server.js` after edits.
#
# Primary name (matches GitHub Actions / typical CI secret name):
FINNHUB_ENDKEY=
#
# Legacy (still supported if FINNHUB_ENDKEY is unset):
# FINNHUB_API_KEY=
